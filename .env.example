# BambuTrack Environment Configuration
# Copy this file to .env and adjust values as needed

# Debug mode (true = DEBUG logging, false = production with INFO logging)
DEBUG=true

# Log level (only used when DEBUG=false)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable file logging (logs written to logs/bambutrack.log)
LOG_TO_FILE=true

# Home Assistant Integration (for HA Add-on deployments)
# When both HA_URL and HA_TOKEN are set, Home Assistant integration is automatically enabled
# and these values override any database settings (read-only in UI)
# HA_URL=http://supervisor/core
# HA_TOKEN=your-long-lived-access-token

# Optional: browser URL for the remote BambuStudio Web/noVNC session.
# Recommended: derive the host from the address the browser is already using for Bambuddy.
# ONLINE_SLICER_BASE_URL={{requestScheme}}://{{requestHost}}:6080/vnc.html?autoconnect=1&resize=remote
# Static host alternative when you only ever use one IP/hostname:
# ONLINE_SLICER_BASE_URL=http://192.168.1.100:6080/vnc.html?autoconnect=1&resize=remote

# Optional: browser URL for Kiri:Moto.
# Default: https://grid.space/kiri/
# ONLINE_KIRI_MOTO_URL=https://grid.space/kiri/

# Optional: public file bucket/object storage base URL.
# Example: https://example-bucket.cos.region.myqcloud.com/BAMBUDDY
# PUBLIC_FILE_BASE_URL=
#
# Optional: separate upload URL for the same public bucket.
# Defaults to PUBLIC_FILE_BASE_URL when omitted.
# PUBLIC_FILE_UPLOAD_BASE_URL=
#
# Optional: AI fallback for queue MakerWorld title cleanup.
# ZHIPUAI_API_KEY=
# MAKERWORLD_TITLE_AI_MODEL=glm-4-plus
#
# Capture a fresh public live frame at most once every N seconds when someone is requesting it.
# Compatible alias: PUBLIC_LIVE_CAMERA_UPLOAD_INTERVAL_SECONDS
# PUBLIC_LIVE_CAMERA_FRAME_INTERVAL_SECONDS=0.5
#
# Rotate the cached file every N seconds and delete the previous one.
# PUBLIC_LIVE_CAMERA_ROTATION_SECONDS=10
#
# Stop caching and delete the local frame if nobody requests it for N seconds.
# PUBLIC_LIVE_CAMERA_IDLE_TIMEOUT_SECONDS=10
#
# Shared password required for queue delete actions.
# Defaults to the queue contact reveal password when not customized.
# QUEUE_ADMIN_ACTION_PASSWORD=sysuzgxytj
